# ============================================================
# Retouch メンバーズサイト - 環境変数サンプル
# 実値は .env.local に書く。コミットしないこと。
# ============================================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === Stripe ===
# ダッシュボード > 開発者 > APIキー / Webhook
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# Webhook 署名シークレット（必須。検証に失敗すると全イベントが破棄される）
# Webhook エンドポイント：{NEXT_PUBLIC_SITE_URL}/api/stripe/webhook
# 受け取るべきイベント：
#   checkout.session.completed
#   invoice.payment_succeeded
#   invoice.payment_failed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   payment_intent.succeeded
#   payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# === サイト URL（Stripe success_url / cancel_url / メール内リンクに使用） ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Retouchメンバーズサイト

# === 通知メール ===
# "audit" (default): audit_logs に記録のみ（送信しない）
# "resend"         : Resend API 経由で送信
NOTIFY_TRANSPORT=audit
# Resend 利用時のみ必要
RESEND_API_KEY=
# 送信元（例: noreply@retouch-members.com）
NOTIFY_FROM_EMAIL=noreply@retouch-members.local
