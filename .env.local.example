NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# === Site ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Retouchメンバーズサイト
